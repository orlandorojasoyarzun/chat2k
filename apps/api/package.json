{
  "name": "@chat2k/api",
  "version": "0.0.0",
  "private": true,
  "description": "Servidor del chat",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
